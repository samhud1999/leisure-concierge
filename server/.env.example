# Copy this file to ".env" and fill in your values.

# --- Supabase (from Project Settings -> API) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the SERVICE ROLE key (server-side only — never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Azure AI Foundry ---
# Project endpoint from Foundry portal → your project → Settings → "Endpoint and keys".
# Looks like: https://<resource>.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_FOUNDRY_ENDPOINT=https://YOUR-RESOURCE.services.ai.azure.com/api/projects/YOUR-PROJECT

# API key from the same page. Keep this server-side only.
AZURE_AI_FOUNDRY_API_KEY=your-azure-ai-foundry-key

# Deployment name of the model in your Foundry project. Default: gpt-5.
# Other options if you've deployed them: gpt-5-mini, gpt-5-nano, gpt-4o, etc.
AZURE_AI_FOUNDRY_MODEL=gpt-5

# API version. 2024-12-01-preview is the safe default for the GPT-5 family.
# Bump as Azure publishes newer preview versions.
AZURE_AI_FOUNDRY_API_VERSION=2024-12-01-preview

# --- Server ---
PORT=3000
# The resort brand name used in the concierge persona.
RESORT_BRAND=RACV

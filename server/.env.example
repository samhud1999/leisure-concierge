# Copy this file to ".env" and fill in your values.

# --- Supabase (from Project Settings -> API) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the SERVICE ROLE key (server-side only — never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Z.ai (GLM models via Anthropic-compatible endpoint) ---
# Get an API key from https://z.ai/model-api
ZAI_API_KEY=your-zai-api-key

# Model. Default is glm-4.7-flash (cheap & fast — good for dev/testing).
# To switch, replace the value below with one of the supported model IDs:
#   glm-4.7-flash   ← cheap & fast (DEFAULT — current dev/test pick)
#   glm-4.7         ← higher-quality 4.7 tier
#   glm-4.6         ← previous-generation flagship
#   glm-4.5         ← stable predecessor
#   glm-4.5-air     ← lightweight 4.5
ZAI_MODEL=glm-4.7-flash

# Optional: override the base URL (Anthropic-compatible).
ZAI_BASE_URL=https://api.z.ai/api/anthropic

# --- Server ---
PORT=3000
# The resort brand name used in the concierge persona.
RESORT_BRAND=RACV

# Copy this file to ".env" and fill in your values.

# --- Supabase (from Project Settings -> API) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the SERVICE ROLE key (server-side only — never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic (from console.anthropic.com) ---
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional: override the model. Defaults to claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Server ---
PORT=3000
# The resort brand name used in the concierge persona.
RESORT_BRAND=RACV
